// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ========== ENUMS ==========

enum UserRole {
  SUPER_ADMIN
  ADMIN
  SALES
  PROJECT_MANAGER
  FINANCE
  CLIENT
}

enum LeadStatus {
  NEW
  CONTACTED
  QUALIFIED
  DISCOVERY_SCHEDULED
  PROPOSAL_SENT
  NEGOTIATION
  WON
  LOST
  ON_HOLD
}

enum LeadSource {
  WEBSITE
  REFERRAL
  SOCIAL_MEDIA
  CAMPAIGN
  DIRECT
  PARTNER
  OTHER
}

enum LeadCategory {
  SERVICE_INQUIRY
  SOLUTION_INQUIRY
  UEP_INQUIRY
  SAAS_TOOLKIT_INQUIRY
  WORKFORCE_INQUIRY
  SUPPORT_INQUIRY
  PARTNERSHIP_INQUIRY
}

enum LeadPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum ProjectStatus {
  DRAFT
  ACTIVE
  DISCOVERY
  IN_DESIGN
  IN_DEVELOPMENT
  IN_REVIEW
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum ProjectCategory {
  CUSTOM_DEVELOPMENT
  UEP_IMPLEMENTATION
  SAAS_TOOLKIT_BUILD
  MOBILE_APP
  DEVOPS_SUPPORT
  INFRASTRUCTURE_SUPPORT
  AI_CHATBOT
  ERP_DEVELOPMENT
  ECOMMERCE
  MARKETING_RETAINER
  WORKFORCE_CONSULTING
}

enum BillingModel {
  FIXED_PRICE
  MILESTONE_BASED
  RECURRING_MONTHLY
  CONSULTATION
}

enum QuotationStatus {
  DRAFT
  SENT
  ACCEPTED
  REJECTED
  EXPIRED
}

enum InvoiceStatus {
  DRAFT
  SENT
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
}

enum PaymentStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
  REFUNDED
}

enum MilestoneStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  SKIPPED
}

enum BlogStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum NotificationType {
  LEAD
  PROJECT
  INVOICE
  PAYMENT
  SYSTEM
}

enum EmailVerificationStatus {
  PENDING
  VERIFIED
}

enum AccountErasureRequestStatus {
  REQUESTED
  RESTRICTED
  ANONYMIZED
  RETAINED_FOR_FINANCE
}

enum CookieConsentDecision {
  ACCEPT_ALL
  ESSENTIAL_ONLY
}

enum AppErrorSeverity {
  INFO
  WARNING
  ERROR
  CRITICAL
}

enum AppErrorSource {
  CLIENT
  SERVER
  RENDER
}

// ========== MODELS ==========

model User {
  id                        String                  @id @default(cuid())
  email                     String                  @unique
  name                      String
  passwordHash              String
  role                      UserRole
  phone                     String?
  avatar                    String?
  avatarStorageKey          String?
  avatarStorageProvider     String?
  emailVerificationStatus   EmailVerificationStatus @default(VERIFIED)
  emailVerifiedAt           DateTime?
  transactionalEmailsEnabled Boolean               @default(true)
  marketingEmailsEnabled    Boolean                @default(true)
  isActive                  Boolean                @default(true)
  createdAt                 DateTime               @default(now())
  updatedAt                 DateTime               @updatedAt

  // Relations
  assignedLeads             Lead[]
  leadNotes                 LeadNote[]
  leadActivities            LeadActivity[]
  managedProjects           Project[]
  projectNotes              ProjectNote[]
  projectStatusChanges      ProjectStatusHistory[]
  clientCommunications      ClientCommunication[]
  createdQuotations         Quotation[]
  createdInvoices           Invoice[]
  fileAttachments           FileAttachment[]
  notifications             Notification[]
  updatedAppSettings        AppSetting[]
  deletedQuotations         Quotation[]            @relation("QuotationDeletedBy")
  auditLogs                 AdminAuditLog[]        @relation("AdminAuditActor")
  emailChangeRequests       EmailChangeRequest[]
  erasureRequests           AccountErasureRequest[]
  cookieConsents            CookieConsentRecord[]
  appErrorLogs              AppErrorLog[]          @relation("AppErrorActor")
  resolvedAppErrorLogs      AppErrorLog[]          @relation("AppErrorResolvedBy")

  @@index([email])
  @@index([role])
  @@index([isActive])
  @@index([emailVerificationStatus])
  @@index([createdAt])
}

model EmailChangeRequest {
  id         String    @id @default(cuid())
  newEmail   String
  token      String    @unique
  expiresAt  DateTime
  verifiedAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  // Foreign Keys
  userId     String
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([newEmail])
  @@index([expiresAt])
  @@index([verifiedAt])
}

model AccountErasureRequest {
  id               String                      @id @default(cuid())
  status           AccountErasureRequestStatus @default(REQUESTED)
  requestedReason  String                      @db.Text
  retentionReason  String?                     @db.Text
  internalNotes    String?                     @db.Text
  requestedAt      DateTime                    @default(now())
  restrictedAt     DateTime?
  resolvedAt       DateTime?
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt
  requestedById    String?
  reviewedById     String?

  userId           String
  user             User                        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([requestedAt])
  @@index([resolvedAt])
}

model CookieConsentRecord {
  id            String                @id @default(cuid())
  policyVersion String
  decision      CookieConsentDecision
  source        String                @default("banner")
  preferences   Json?
  ipAddress     String?
  userAgent     String?
  acceptedAt    DateTime              @default(now())
  createdAt     DateTime              @default(now())

  visitorId     String
  userId        String?
  user          User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([visitorId])
  @@index([userId])
  @@index([policyVersion])
  @@index([acceptedAt])
}

model AppErrorLog {
  id            String           @id @default(cuid())
  fingerprint   String           @unique
  title         String
  message       String           @db.Text
  severity      AppErrorSeverity @default(ERROR)
  source        AppErrorSource   @default(SERVER)
  route         String?
  area          String?
  method        String?
  statusCode    Int?
  stack         String?          @db.Text
  metadata      Json?
  occurrences   Int              @default(1)
  firstSeenAt   DateTime         @default(now())
  lastSeenAt    DateTime         @default(now())
  lastAlertedAt DateTime?
  isResolved    Boolean          @default(false)
  resolvedAt    DateTime?
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  userId        String?
  user          User?            @relation("AppErrorActor", fields: [userId], references: [id], onDelete: SetNull)
  resolvedById  String?
  resolvedBy    User?            @relation("AppErrorResolvedBy", fields: [resolvedById], references: [id], onDelete: SetNull)

  @@index([severity])
  @@index([source])
  @@index([isResolved])
  @@index([lastSeenAt])
  @@index([route])
  @@index([userId])
  @@index([resolvedById])
}

model Lead {
  id                  String        @id @default(cuid())
  fullName            String
  companyName         String?
  email               String
  phone               String?
  location            String?
  country             String?
  source              LeadSource
  category            LeadCategory
  offeringType        String?
  selectedService     String?
  selectedSolution    String?
  budgetRange         String?
  projectType         String?
  businessStage       String?
  timeline            String?
  requirementsSummary String?
  priority            LeadPriority  @default(MEDIUM)
  status              LeadStatus    @default(NEW)
  followUpDate        DateTime?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  // Foreign Keys
  assignedToId        String?
  assignedTo          User?         @relation(fields: [assignedToId], references: [id], onDelete: SetNull)
  convertedClientId   String?
  convertedClient     Client?       @relation(fields: [convertedClientId], references: [id], onDelete: SetNull)
  convertedProjectId  String?
  convertedProject    Project?      @relation("LeadConvertedProject", fields: [convertedProjectId], references: [id], onDelete: SetNull)

  // Relations
  notes               LeadNote[]
  activities          LeadActivity[]
  quotations          Quotation[]
  projects            Project[]     @relation("ProjectLead")

  @@index([email])
  @@index([status])
  @@index([priority])
  @@index([source])
  @@index([category])
  @@index([assignedToId])
  @@index([convertedClientId])
  @@index([convertedProjectId])
  @@index([createdAt])
}

model LeadNote {
  id        String    @id @default(cuid())
  content   String    @db.Text
  createdAt DateTime  @default(now())

  // Foreign Keys
  leadId    String
  lead      Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@index([userId])
  @@index([createdAt])
}

model LeadActivity {
  id          String    @id @default(cuid())
  type        String
  description String
  metadata    Json?
  createdAt   DateTime  @default(now())

  // Foreign Keys
  leadId      String
  lead        Lead      @relation(fields: [leadId], references: [id], onDelete: Cascade)
  userId      String?
  user        User?     @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([leadId])
  @@index([userId])
  @@index([createdAt])
}

model Client {
  id            String    @id @default(cuid())
  type          String    @default("company")
  companyName   String?
  contactName   String?
  email         String    @unique
  phone         String?
  billingAddress String?
  city          String?
  state         String?
  country       String?
  postalCode    String?
  gstNumber     String?
  panNumber     String?
  bankName      String?
  bankAccountNumber String?
  ifscCode      String?
  notes         String?   @db.Text
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  documents     ClientDocument[]
  communications ClientCommunication[]
  projects      Project[]
  invoices      Invoice[]
  quotations    Quotation[]
  convertedFromLeads Lead[]

  @@index([email])
  @@index([type])
  @@index([isActive])
  @@index([createdAt])
}

model ClientDocument {
  id         String    @id @default(cuid())
  name       String
  url        String
  type       String?
  uploadedAt DateTime  @default(now())

  // Foreign Keys
  clientId   String
  client     Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
}

model ClientCommunication {
  id        String    @id @default(cuid())
  type      String
  subject   String?
  content   String    @db.Text
  createdAt DateTime  @default(now())

  // Foreign Keys
  clientId  String
  client    Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([userId])
  @@index([createdAt])
}

model Project {
  id                  String        @id @default(cuid())
  name                String
  currency            String        @default("INR")
  category            ProjectCategory
  description         String?       @db.Text
  scope               String?       @db.Text
  startDate           DateTime?
  estimatedEndDate    DateTime?
  priority            String        @default("MEDIUM")
  status              ProjectStatus @default(DRAFT)
  budget              Decimal?      @db.Decimal(12, 2)
  billingModel        BillingModel  @default(FIXED_PRICE)
  progressPercent     Int           @default(0)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  // Foreign Keys
  clientId            String
  client              Client        @relation(fields: [clientId], references: [id], onDelete: Restrict)
  leadId              String?
  lead                Lead?         @relation("ProjectLead", fields: [leadId], references: [id], onDelete: SetNull)
  managerId           String?
  manager             User?         @relation(fields: [managerId], references: [id], onDelete: SetNull)

  // Relations
  milestones          ProjectMilestone[]
  notes               ProjectNote[]
  documents           ProjectDocument[]
  statusHistory       ProjectStatusHistory[]
  uepDetail           UepProjectDetail?
  toolkitDetail       ToolkitProjectDetail?
  invoices            Invoice[]
  convertedFromLeads  Lead[]        @relation("LeadConvertedProject")

  @@index([clientId])
  @@index([leadId])
  @@index([managerId])
  @@index([status])
  @@index([category])
  @@index([createdAt])
}

model ProjectMilestone {
  id              String          @id @default(cuid())
  title           String
  description     String?         @db.Text
  dueDate         DateTime?
  status          MilestoneStatus @default(PENDING)
  paymentAmount   Decimal?        @db.Decimal(12, 2)
  order           Int
  completedAt     DateTime?
  createdAt       DateTime        @default(now())

  // Foreign Keys
  projectId       String
  project         Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([status])
}

model ProjectNote {
  id              String    @id @default(cuid())
  content         String    @db.Text
  isClientVisible Boolean   @default(false)
  createdAt       DateTime  @default(now())

  // Foreign Keys
  projectId       String
  project         Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId          String
  user            User      @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([projectId])
  @@index([userId])
}

model ProjectDocument {
  id        String    @id @default(cuid())
  name      String
  url       String
  type      String?
  uploadedAt DateTime @default(now())

  // Foreign Keys
  projectId String
  project   Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ProjectStatusHistory {
  id         String        @id @default(cuid())
  fromStatus ProjectStatus
  toStatus   ProjectStatus
  note       String?       @db.Text
  createdAt  DateTime      @default(now())

  // Foreign Keys
  projectId  String
  project    Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  changedById String
  changedBy  User          @relation(fields: [changedById], references: [id], onDelete: Restrict)

  @@index([projectId])
  @@index([changedById])
}

model UepProjectDetail {
  id                  String    @id @default(cuid())
  institutionType     String?
  selectedModules     String[]
  customizationScope  String?   @db.Text
  deploymentModel     String?
  onboardingPlan      String?   @db.Text
  supportPlan         String?   @db.Text

  // Foreign Keys
  projectId           String    @unique
  project             Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ToolkitProjectDetail {
  id                      String    @id @default(cuid())
  baseModules             String[]
  customModules           String[]
  architecturePlan        String?   @db.Text
  launchChecklist         String?   @db.Text
  saasReadinessChecklist  String?   @db.Text

  // Foreign Keys
  projectId               String    @unique
  project                 Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model Quotation {
  id              String            @id @default(cuid())
  quotationNumber String            @unique
  currency        String            @default("INR")
  title           String
  description     String?           @db.Text
  validUntil      DateTime?
  termsNotes      String?           @db.Text
  status          QuotationStatus   @default(DRAFT)
  subtotal        Decimal           @default(0) @db.Decimal(12, 2)
  taxAmount       Decimal           @default(0) @db.Decimal(12, 2)
  discountAmount  Decimal           @default(0) @db.Decimal(12, 2)
  total           Decimal           @default(0) @db.Decimal(12, 2)
  template        String?
  deletedAt       DateTime?
  deleteReason    String?           @db.Text
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  // Foreign Keys
  leadId          String?
  lead            Lead?             @relation(fields: [leadId], references: [id], onDelete: SetNull)
  clientId        String?
  client          Client?           @relation(fields: [clientId], references: [id], onDelete: SetNull)
  createdById     String
  createdBy       User              @relation(fields: [createdById], references: [id], onDelete: Restrict)
  deletedById     String?
  deletedBy       User?             @relation("QuotationDeletedBy", fields: [deletedById], references: [id], onDelete: SetNull)

  // Relations
  items           QuotationItem[]
  invoices        Invoice[]

  @@index([quotationNumber])
  @@index([leadId])
  @@index([clientId])
  @@index([createdById])
  @@index([deletedAt])
  @@index([deletedById])
  @@index([status])
  @@index([createdAt])
}

model QuotationItem {
  id            String    @id @default(cuid())
  description   String    @db.Text
  quantity      Decimal   @default(1) @db.Decimal(12, 4)
  unitPrice     Decimal   @db.Decimal(12, 2)
  taxPercent    Decimal   @default(0) @db.Decimal(5, 2)
  discount      Decimal   @default(0) @db.Decimal(12, 2)
  total         Decimal   @db.Decimal(12, 2)
  order         Int

  // Foreign Keys
  quotationId   String
  quotation     Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)

  @@index([quotationId])
}

model Invoice {
  id                String        @id @default(cuid())
  invoiceNumber     String        @unique
  currency          String        @default("INR")
  issueDate         DateTime      @default(now())
  dueDate           DateTime
  subtotal          Decimal       @db.Decimal(12, 2)
  taxAmount         Decimal       @default(0) @db.Decimal(12, 2)
  total             Decimal       @db.Decimal(12, 2)
  paidAmount        Decimal       @default(0) @db.Decimal(12, 2)
  notes             String?       @db.Text
  status            InvoiceStatus @default(DRAFT)
  billingCategory   String?
  razorpayOrderId   String?
  razorpayPaymentLink String?
  createdAt         DateTime      @default(now())
  updatedAt         DateTime      @updatedAt

  // Foreign Keys
  clientId          String
  client            Client        @relation(fields: [clientId], references: [id], onDelete: Restrict)
  projectId         String?
  project           Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  quotationId       String?
  quotation         Quotation?    @relation(fields: [quotationId], references: [id], onDelete: SetNull)
  createdById       String
  createdBy         User          @relation(fields: [createdById], references: [id], onDelete: Restrict)

  // Relations
  items             InvoiceItem[]
  payments          Payment[]

  @@index([invoiceNumber])
  @@index([clientId])
  @@index([projectId])
  @@index([quotationId])
  @@index([createdById])
  @@index([status])
  @@index([createdAt])
}

model InvoiceItem {
  id          String    @id @default(cuid())
  description String    @db.Text
  quantity    Decimal   @default(1) @db.Decimal(12, 4)
  unitPrice   Decimal   @db.Decimal(12, 2)
  taxPercent  Decimal   @default(0) @db.Decimal(5, 2)
  total       Decimal   @db.Decimal(12, 2)
  order       Int

  // Foreign Keys
  invoiceId   String
  invoice     Invoice   @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
}

model Payment {
  id                String        @id @default(cuid())
  amount            Decimal       @db.Decimal(12, 2)
  method            String?
  razorpayOrderId   String?
  razorpayPaymentId String?
  razorpaySignature String?
  status            PaymentStatus @default(PENDING)
  paidAt            DateTime?
  createdAt         DateTime      @default(now())

  // Foreign Keys
  invoiceId         String
  invoice           Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)

  @@index([invoiceId])
  @@index([status])
  @@index([razorpayOrderId])
  @@index([razorpayPaymentId])
}

model RazorpayWebhookLog {
  id          String    @id @default(cuid())
  eventType   String
  orderId     String?
  paymentId   String?
  payload     Json
  verified    Boolean   @default(false)
  processedAt DateTime?
  error       String?   @db.Text
  createdAt   DateTime  @default(now())

  @@index([eventType])
  @@index([orderId])
  @@index([paymentId])
  @@index([verified])
}

model AdminAuditLog {
  id         String    @id @default(cuid())
  entityType String
  entityId   String
  action     String
  summary    String
  metadata   Json?
  createdAt  DateTime  @default(now())

  userId     String?
  user       User?     @relation("AdminAuditActor", fields: [userId], references: [id], onDelete: SetNull)

  @@index([entityType])
  @@index([entityId])
  @@index([action])
  @@index([createdAt])
  @@index([userId])
}

model Service {
  id                String    @id @default(cuid())
  title             String
  slug              String    @unique
  shortDescription  String
  fullContent       String?   @db.Text
  icon              String?
  order             Int       @default(0)
  isActive          Boolean   @default(true)
  isMarketingOnly   Boolean   @default(false)
  seoTitle          String?
  seoDescription    String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([slug])
  @@index([isActive])
  @@index([order])
}

model Solution {
  id                String    @id @default(cuid())
  title             String
  slug              String    @unique
  shortDescription  String
  fullContent       String?   @db.Text
  icon              String?
  modules           String[]
  targetCustomers   String?
  implementationModel String?
  order             Int       @default(0)
  isActive          Boolean   @default(true)
  isMarketingOnly   Boolean   @default(false)
  seoTitle          String?
  seoDescription    String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  @@index([slug])
  @@index([isActive])
  @@index([order])
}

model BlogPost {
  id            String    @id @default(cuid())
  title         String
  slug          String    @unique
  excerpt       String?
  content       String?   @db.Text
  author        String?
  coverImage    String?
  status        BlogStatus @default(DRAFT)
  tags          String[]
  publishedAt   DateTime?
  seoTitle      String?
  seoDescription String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([slug])
  @@index([status])
  @@index([publishedAt])
}

model CaseStudy {
  id        String    @id @default(cuid())
  title     String
  slug      String    @unique
  client    String?
  challenge String?   @db.Text
  solution  String?   @db.Text
  techStack String[]
  timeline  String?
  results   String?   @db.Text
  screenshots String[]
  industry  String?
  order     Int       @default(0)
  isActive  Boolean   @default(true)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([slug])
  @@index([isActive])
  @@index([order])
}

model ContactSubmission {
  id                  String    @id @default(cuid())
  name                String
  email               String
  phone               String?
  company             String?
  serviceInterest     String?
  solutionInterest    String?
  budgetRange         String?
  timeline            String?
  businessType        String?
  message             String    @db.Text
  status              String    @default("new")
  convertedToLeadId   String?
  createdAt           DateTime  @default(now())

  @@index([email])
  @@index([status])
  @@index([createdAt])
}

model Notification {
  id        String           @id @default(cuid())
  title     String
  message   String           @db.Text
  type      NotificationType
  isRead    Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())

  // Foreign Keys
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

model AppSetting {
  id          String    @id @default(cuid())
  key         String    @unique
  group       String
  label       String?
  description String?   @db.Text
  value       Json
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  // Foreign Keys
  updatedById String?
  updatedBy   User?     @relation(fields: [updatedById], references: [id], onDelete: SetNull)

  @@index([group])
  @@index([updatedById])
}

model FileAttachment {
  id          String    @id @default(cuid())
  entityType  String
  entityId    String
  name        String
  url         String
  storageKey  String?
  storageProvider String   @default("local")
  mimeType    String?
  size        Int?
  createdAt   DateTime  @default(now())

  // Foreign Keys
  uploadedById String?
  uploadedBy   User?     @relation(fields: [uploadedById], references: [id], onDelete: SetNull)

  @@index([entityType])
  @@index([entityId])
  @@index([uploadedById])
}
