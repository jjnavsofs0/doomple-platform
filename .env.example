# Database
DATABASE_URL="postgresql://user:password@localhost:5432/doomple_dev"

# NextAuth
NEXTAUTH_SECRET="your-secret-key-here-min-32-chars"
NEXTAUTH_URL="http://localhost:3000"

# Razorpay
RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxxx"
RAZORPAY_KEY_SECRET="your_razorpay_secret_key"
RAZORPAY_WEBHOOK_SECRET="your_webhook_secret"
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_xxxxxxxxxxxxx"
# Optional: major-unit transaction limit guardrails, for example 500000 for INR.
RAZORPAY_MAX_TRANSACTION_AMOUNT=""
RAZORPAY_MAX_TRANSACTION_AMOUNT_INR=""

# App Config
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NEXT_PUBLIC_COOKIE_POLICY_VERSION="2026-03-20"

# AWS S3
AWS_REGION="ap-south-1"
AWS_S3_PUBLIC_BUCKET="doomple-user-data-public"
AWS_S3_PRIVATE_BUCKET="doomple-user-data-private"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# AWS SES
AWS_SES_REGION="ap-south-1"
AWS_SES_ACCESS_KEY_ID=""
AWS_SES_SECRET_ACCESS_KEY=""
AWS_SES_FROM_EMAIL="noreply@doomple.com"
AWS_SES_REPLY_TO="sneha@doomple.com"
APP_ERROR_ALERT_EMAILS="ops@doomple.com,sneha@doomple.com"

# Pusher Realtime
PUSHER_APP_ID=""
PUSHER_KEY=""
PUSHER_SECRET=""
PUSHER_CLUSTER="ap2"
NEXT_PUBLIC_PUSHER_KEY=""
NEXT_PUBLIC_PUSHER_CLUSTER="ap2"
